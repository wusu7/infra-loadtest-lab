{
  "uid": "springboot-load-test",
  "title": "Spring Boot Load Test",
  "tags": ["spring-boot", "load-test"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-boot-test-api\"}[1m]))",
          "legendFormat": "requests/sec"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP p95 Latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"spring-boot-test-api\"}[1m])) by (le))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Process CPU",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{job=\"spring-boot-test-api\"}",
          "legendFormat": "process cpu"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JVM Memory Used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{job=\"spring-boot-test-api\"}) by (area)",
          "legendFormat": "{{area}}"
        }
      ]
    }
  ]
}
