{
  "uid": "k6-load-test",
  "title": "k6 Load Test",
  "tags": ["k6", "load-test"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "k6 HTTP Requests",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k6_http_reqs_total[1m]))",
          "legendFormat": "k6 http reqs/sec"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "k6 p95 Duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95 duration"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "k6 Checks",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k6_checks_total[1m])) by (status)",
          "legendFormat": "checks {{status}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "k6 Virtual Users",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "k6_vus",
          "legendFormat": "virtual users"
        }
      ]
    }
  ]
}
