{
  "uid": "kafka-load-test",
  "title": "Kafka Load Test",
  "tags": ["kafka", "load-test"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Kafka Brokers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "kafka_brokers{job=\"kafka-exporter\"}",
          "legendFormat": "brokers"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Topic Partitions",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kafka_topic_partitions{job=\"kafka-exporter\"}) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Topic Current Offset",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kafka_topic_partition_current_offset{job=\"kafka-exporter\"}) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    }
  ]
}
