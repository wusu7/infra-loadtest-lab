{
  "uid": "redis-load-test",
  "title": "Redis Load Test",
  "tags": ["redis", "load-test"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Redis Commands",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(redis_commands_processed_total{job=\"redis-exporter\"}[1m])",
          "legendFormat": "commands/sec"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Redis Memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "redis_memory_used_bytes{job=\"redis-exporter\"}",
          "legendFormat": "used memory"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Connected Clients",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "redis_connected_clients{job=\"redis-exporter\"}",
          "legendFormat": "clients"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Redis Up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "redis_up{job=\"redis-exporter\"}",
          "legendFormat": "redis up"
        }
      ]
    }
  ]
}
